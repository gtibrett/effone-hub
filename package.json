{
	"name": "@gtibrett/effone-hub",
	"version": "2.0.0-alpha.0",
	"license": "MIT",
	"private": true,
	"engines": {
		"node": "^24.0.0"
	},
	"packageManager": "pnpm@11.1.2",
	"scripts": {
		"prepare": "node -e \"process.exit(process.env.VERCEL?0:1)\" || husky",
		"db:start": "pnpm --filter @gtibrett/effone-hub-graph-db start",
		"db:stop": "pnpm --filter @gtibrett/effone-hub-graph-db stop",
		"dev": "pnpm --parallel --filter @gtibrett/effone-hub-api --filter @gtibrett/effone-hub-site dev",
		"api:dev": "pnpm --filter @gtibrett/effone-hub-api dev",
		"site:dev": "pnpm --filter @gtibrett/effone-hub-site dev",
		"site:build": "pnpm --filter @gtibrett/effone-hub-site build",
		"site:start": "pnpm --filter @gtibrett/effone-hub-site start",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"lint:fix:unsafe": "biome check --write --unsafe",
		"format": "biome format",
		"format:fix": "biome format --write"
	},
	"lint-staged": {
		"packages/site/src/**/*.{js,jsx,ts,tsx,json,css}": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		],
		"packages/site/{next.config.mjs,postcss.config.mjs,tsconfig.json}": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.6",
		"tsx": "^4.22.3"
	}
}
