# ── effone-hub site (Next.js) ──
# Only vars actually read by the app. Copy to .env and fill in.

# GraphQL API endpoint — the standalone packages/api deployment (a SEPARATE origin),
# so it must be an absolute URL.
# Local dev: optional — falls back to http://localhost:4000/graphql.
# On Vercel: REQUIRED — the app throws at runtime if unset.
NEXT_PUBLIC_GRAPHQL_API_URL=

# Google Analytics measurement ID. Optional — omit to disable the GA script.
NEXT_PUBLIC_GA_TRACKING_ID=

# GraphQL codegen schema source (`pnpm codegen`). Optional — defaults to the
# committed SDL at ../api/schema.graphql; set to a live URL to codegen against a
# running API instead.
CODEGEN_SCHEMA_URL=

# Shared secret for POST /api/cron/revalidate, checked as `Authorization: Bearer <secret>`
# against the GitHub Actions ingest runner. The route fails closed (500) if unset, so
# any deployment serving it REQUIRES this. Must match the api ingest job's CRON_SECRET.
CRON_SECRET=

# ── Vercel platform-injected — do NOT set these manually ──
# VERCEL                          auto-set to "1" on Vercel; gates the NEXT_PUBLIC_GRAPHQL_API_URL requirement.
# VERCEL_AUTOMATION_BYPASS_SECRET auto-injected; lets server-side (RSC/build) fetches bypass
#                                 SSO on protected api preview deploys. Not needed locally.
