# ── GraphQL server (src/server.ts, src/graphile.config.ts) ──

# Postgres connection for PostGraphile. REQUIRED (boot throws if unset).
# Local dev = the docker compose DB (packages/database):
#   postgres://postgres:effonehub@localhost:5432/postgres
# Prod = Neon pooled URL.
POSTGRES_URL=

# Comma-separated schemas PostGraphile introspects. Default: f1db,app
POSTGRES_SCHEMA=f1db,app

# Fastify listen port. Site dev points NEXT_PUBLIC_GRAPHQL_API_URL at this. Default: 4000
PORT=4000

# Fastify bind host. Default: 0.0.0.0
HOST=0.0.0.0

# Expose GraphiQL at /graphiql when "true". Default: false
ENABLE_GRAPHIQL=false

# ── Ingest job (scripts/run-ingest.ts via `pnpm ingest` — runs in CI, not local dev) ──

# Shared secret sent as `Authorization: Bearer <secret>` to the site's revalidate
# endpoint after a successful ingest. Must match the site deployment's CRON_SECRET.
CRON_SECRET=

# Site endpoint pinged to bust Cache Components tags post-ingest.
# Default: https://effonehub.com/api/cron/revalidate
REVALIDATE_URL=

# Max races to backfill lap times for per ingest run. Default: 500
MAX_LAP_RACES=

# NODE_ENV is runtime-managed (not set here): when "production", schema.graphql
# SDL export is skipped (disk is ephemeral on Vercel).
