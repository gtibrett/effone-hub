{
	"compilerOptions": {
		"lib": ["esnext"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "esnext",
		"types": ["node"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"incremental": true
	},
	"include": ["src/**/*.ts", "graphile.config.ts"],
	"exclude": ["node_modules"]
}
